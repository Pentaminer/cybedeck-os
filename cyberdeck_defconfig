# 脌冒玫猫貌氓锚貌贸冒脿 猫 脧冒卯枚氓帽帽卯冒 (Cortex-A7)
BR2_arm=y
BR2_cortex_a7=y
BR2_ARM_EABIHF=y
BR2_ARM_FPU_VFPV3D16=y

# 脕脿莽卯芒脿每 帽猫帽貌氓矛脿 猫 脪贸毛梅氓茅铆
BR2_TOOLCHAIN_BUILDROOT_GLIBC=y
BR2_KERNEL_HEADERS_6_18=y
BR2_GCC_VERSION_14_X=y

# 脽盲冒卯 Linux (脕脿莽卯芒没茅 锚卯铆么猫茫 茂卯盲 芒猫冒貌贸脿毛眉铆贸镁 茂毛脿貌贸 vexpress)
BR2_LINUX_KERNEL=y
BR2_LINUX_KERNEL_CUSTOM_VERSION=y
BR2_LINUX_KERNEL_CUSTOM_VERSION_VALUE="6.18.7"
BR2_LINUX_KERNEL_DEFCONFIG="vexpress"
BR2_LINUX_KERNEL_ZIMAGE=y

# 脠铆貌氓冒茂冒氓貌脿貌卯冒 Lua 5.4 猫 芒脿忙铆没氓 矛卯盲贸毛猫
BR2_PACKAGE_LUA=y
BR2_PACKAGE_LUA_5_4=y
BR2_PACKAGE_LUASOCKET=y
BR2_PACKAGE_LUAFILESYSTEM=y

# 脧脿锚氓貌铆没茅 矛氓铆氓盲忙氓冒 OPKG (脌毛眉貌氓冒铆脿貌猫芒脿 APT)
BR2_PACKAGE_OPKG=y

# 脫盲卯谩铆没氓 贸貌猫毛猫貌没 盲毛每 貌氓冒矛猫铆脿毛脿
BR2_PACKAGE_TMUX=y
BR2_PACKAGE_NANO=y

# 脙冒脿么猫梅氓帽锚猫茅 帽氓冒芒氓冒 X.Org (X11)
BR2_PACKAGE_XORG7=y
BR2_PACKAGE_XSERVER_XORG_SERVER=y
BR2_PACKAGE_XSERVER_XORG_SERVER_MODULAR=y

# 脗猫盲氓卯盲冒脿茅芒氓冒 猫 芒芒卯盲 (脤没酶眉 + 脢毛脿芒脿 盲毛每 QEMU)
BR2_PACKAGE_XDRIVER_XF86_VIDEO_FBDEV=y
BR2_PACKAGE_XDRIVER_XF86_INPUT_KEYBOARD=y
BR2_PACKAGE_XDRIVER_XF86_INPUT_MOUSE=y
BR2_PACKAGE_XDRIVER_XF86_INPUT_EVDEV=y

# 脙冒脿么猫梅氓帽锚脿每 卯谩卯毛卯梅锚脿 (脣氓茫锚卯芒氓帽铆没茅 脦锚卯铆铆没茅 脤氓铆氓盲忙氓冒)
BR2_PACKAGE_OPENBOX=y

# 脫貌猫毛猫貌没 茫冒脿么猫锚猫 (脻矛贸毛每貌卯冒 貌氓冒矛猫铆脿毛脿 xterm)
BR2_PACKAGE_XTERM=y
BR2_PACKAGE_XINIT=y

# 脭卯冒矛脿貌 么脿茅毛卯芒卯茅 帽猫帽貌氓矛没 铆脿 芒没玫卯盲氓
BR2_TARGET_ROOTFS_EXT2=y
BR2_TARGET_ROOTFS_EXT2_4=y
# BR2_TARGET_ROOTFS_TAR is not set
